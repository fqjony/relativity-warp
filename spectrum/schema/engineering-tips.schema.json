{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["Group", "Tips"],
    "properties": {
      "Group": { "type": "string", "minLength": 1 },
      "Tips": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["Tip", "Why"],
          "properties": {
            "Tip": { "type": "string", "minLength": 1 },
            "Why": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
